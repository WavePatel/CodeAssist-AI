# Copy this file to .env and fill in your values
# Gemini/OpenAI API key - set to "demo" or leave blank for demo mode
GEMINI_API_KEY=

# Optional: override Gemini model name (defaults to gemini-2.5-flash)
GEMINI_MODEL=

# Application environment (development/production)
APP_ENV=development

# Logging level (debug, info, warning, error, critical)
LOG_LEVEL=info
